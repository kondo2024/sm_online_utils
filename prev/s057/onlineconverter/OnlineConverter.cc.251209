  fTGT_X = kNaN;
  fTGT_Y = kNaN;
  fTGT_A = kNaN;
  fTGT_B = kNaN;

  if(abs(fBDC1_X)<40&&abs(fBDC1_Y)<40&&abs(fBDC2_X)<40&&abs(fBDC2_Y)<40){
    //Target Position
    TVector3 bdc1Position(fBDC1_X,fBDC1_Y,kBDC1_Z);
    TVector3 bdc2Position(fBDC2_X,fBDC2_Y,kBDC2_Z);
    TVector3 beamDirection=bdc2Position-bdc1Position;
