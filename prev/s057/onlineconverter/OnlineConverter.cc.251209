  fHistArray.push_back(hf51bxf5dtx);

  htof37f5dtx = new TH2D("tof37f5dtx", "ToF37 (BR) vs F5 tdiff X", 200,-150,100, 200,235,260);
  htof37f5dtx2 = new TH2D("tof37f5dtx2", "ToF37 (BR) vs F5 tdiff X (F5X g)", 200,-150,100, 200,235,260);
  // hzvstof37 = new TH2D("zvstof37", "Z vs ToF37 (BR)", 200,235,260, 200,18,25);
