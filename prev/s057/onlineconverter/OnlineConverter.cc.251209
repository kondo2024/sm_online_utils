  hf5dt_f5x = new TH2D("f5dt_f5x","F5 Pla tdiff (Mult0) vs F5X PPAC",100,-150,150, 100,-400,100);
  hf5dt2_f5x = new TH2D("f5dt2_f5x","F5 Pla tdiff (TDC) vs F5X PPAC",100,-150,150, 100,-600,0);
  hf5dt_f51ax = new TH2D("f5dt_f51ax","F5 Pla tdiff (Mult0) vs F5 X PPAC 1A",100,-150,150, 100,-400,100);
  hf5dt_f51bx = new TH2D("f5dt_f51bx","F5 Pla tdiff (Mult0) vs F5 X PPAC 1B",100,-150,150, 100,-400,100);
  hf5dt_f52ax = new TH2D("f5dt_f52ax","F5 Pla tdiff (Mult0) vs F5 X PPAC 2A",100,-150,150, 100,-400,100);
  hf5dt_f52bx = new TH2D("f5dt_f52bx","F5 Pla tdiff (Mult0) vs F5 X PPAC 1B",100,-150,150, 100,-400,100);
  hf51bxf5dt = new TH2D("f51bxf5dt", "F5X PPAC1B F5 tdiff", 500,-500,0, 500,-150,100);
  hf51bxf5dtx = new TH2D("f51bxf5dtx", "F5X PPAC1B F5 tdiff X", 500,-150,100, 500,-150,100);

  fHistArray.push_back(hf5dt_f5x);
  fHistArray.push_back(hf5dt2_f5x);
  fHistArray.push_back(hf5dt_f51ax);
  fHistArray.push_back(hf5dt_f51bx);
  fHistArray.push_back(hf5dt_f52ax);
  fHistArray.push_back(hf5dt_f52bx);
