  fHistArray.push_back(htof37f5dtx2);
  fHistArray.push_back(hzvstof37);
  fHistArray.push_back(hzvstof372);
  fHistArray.push_back(hbeta37tof37);
  fHistArray.push_back(hbeta37tof372);
  fHistArray.push_back(hBetheFbeta37);
  fHistArray.push_back(hBetheFbeta372);
  fHistArray.push_back(hBrhoF5beta37);
  fHistArray.push_back(hAoQBrhoF5);
  fHistArray.push_back(hzvsaoq);
  fHistArray.push_back(hdEBetheF);
  */

  fIsHistBooked = true;
}
//______________________________________________________________________________
void OnlineConverter::FillUserHist()
{
  TArtStoreManager *sman = TArtStoreManager::Instance();
  //TClonesArray *a = sman->FindDataContainer("NEBULAPla");

  //--------------------------------------
  // Beam PID
  TClonesArray *pla_array = (TClonesArray*)sman->FindDataContainer("BigRIPSPlastic");

  TArtPlastic *F3Pla = 0;
  TArtPlastic *F5Pla = 0;
  TArtPlastic *F7Pla = 0;
  TArtPlastic *F13APla = 0;
  TArtPlastic *F13BPla = 0;
  TArtPlastic *SBV = 0;

  int n=pla_array->GetEntries();
  for (Int_t i=0;i<n;++i){
    TArtPlastic* pla = (TArtPlastic*)pla_array->At(i);
    Int_t ID= pla->GetID();
    if (ID==1){// F3 plastic
      F3Pla = pla;
    }else if (ID==2){// F5 plastic
      F5Pla = pla;
    }else if (ID==3){// F7 plastic
      F7Pla = pla;
    }else if (ID==4){// F13A SBT1
      F13APla = pla;
    }else if (ID==5){// F13B SBT2
      F13BPla = pla;
    }else if (ID==6){// SBV
      SBV = pla;
    }
  }

  //printf("F3Pla\n ");
  //dump_pla(F3Pla);
  //printf("F5Pla\n ");
  //dump_pla(F5Pla);
  //printf("F7Pla\n ");
  //dump_pla(F7Pla);
  //printf("F13APla\n ");
  //dump_pla(F13APla);
  //printf("F13BPla\n ");
  //dump_pla(F13BPla);
  //printf("SBV\n ");
  //dump_pla(SBV);
  //printf("\n");
  //printf("F7: %d, %d\n", F7Pla->GetQTCLRawWidth(), F7Pla->GetQTCRRawWidth());

  fF3TLRaw = kNaN;
  fF3TRRaw = kNaN;
  fF3QLRaw = kNaN;
  fF3QRRaw = kNaN;
  fF3QTCLRawStart = kNaN;
  fF3QTCRRawStart = kNaN;
  fF3QTCLRawWidth = kNaN;
  fF3QTCRRawWidth = kNaN;
  fF3NHitL = 0;
  fF3NHitR = 0;

  fF5TLRaw = kNaN;
  fF5TRRaw = kNaN;
  fF5QLRaw = kNaN;
  fF5QRRaw = kNaN;
  fF5QTCLRawStart = kNaN;
  fF5QTCRRawStart = kNaN;
  fF5QTCLRawWidth = kNaN;
  fF5QTCRRawWidth = kNaN;
  fF5NHitL = 0;
  fF5NHitR = 0;

  fF7TLRaw = kNaN;
  fF7TRRaw = kNaN;
  fF7QLRaw = kNaN;
  fF7QRRaw = kNaN;
  fF7QTCLRawStart = kNaN;
  fF7QTCRRawStart = kNaN;
  fF7QTCLRawWidth = kNaN;
  fF7QTCRRawWidth = kNaN;
  fF7NHitL = 0;
  fF7NHitR = 0;

  fF13AQLRaw = kNaN;
  fF13AQRRaw = kNaN;
  fF13BQLRaw = kNaN;
  fF13BQRRaw = kNaN;

  for (Int_t i=0; i<kArraySize; ++i) {
    fF3MulHitTDCL[i] = kNaN;
    fF3MulHitTDCR[i] = kNaN;
    fF5MulHitTDCL[i] = kNaN;
    fF5MulHitTDCR[i] = kNaN;
    fF7MulHitTDCL[i] = kNaN;
    fF7MulHitTDCR[i] = kNaN;
  }

  fF3T_BR = kNaN;
  fF3T_SM = kNaN;
  fF5DT = kNaN;
  fF5Xpla = kNaN;
  fF7T_BR = kNaN;
  fF7T_SM = kNaN;
  fF7Q = kNaN;
  fToF37_BR = kNaN;
  fToF37_SM = kNaN;

  fbeta37 = kNaN;
  fgamma37 = kNaN;
  fBetheF = kNaN;
  fZ_tmp = kNaN;
  fZ = kNaN;
  fdelta = kNaN;
  fBrhoF5 = kNaN;
  fAoQ = kNaN;
  fdE = kNaN;

  if (F3Pla !=0) {
    fF3TLRaw = F3Pla->GetTLRaw()>0 ? F3Pla->GetTLRaw() : kNaN;
    fF3TRRaw = F3Pla->GetTRRaw()>0 ? F3Pla->GetTRRaw() : kNaN;
    fF3QLRaw = F3Pla->GetQLRaw();
    fF3QRRaw = F3Pla->GetQRRaw();
    fF3QTCLRawStart = F3Pla->GetQTCLRawStart()>0 ? F3Pla->GetQTCLRawStart() : kNaN;
    fF3QTCRRawStart = F3Pla->GetQTCRRawStart()>0 ? F3Pla->GetQTCRRawStart() : kNaN;
    fF3QTCLRawWidth = F3Pla->GetQTCLRawWidth()>0 ? F3Pla->GetQTCLRawWidth() : kNaN;
    fF3QTCRRawWidth = F3Pla->GetQTCRRawWidth()>0 ? F3Pla->GetQTCRRawWidth() : kNaN;
    fF3NHitL = F3Pla->GetNHitL();
    fF3NHitR = F3Pla->GetNHitR();
    for (Int_t i=0; i<fF3NHitL; ++i) {
      fF3MulHitTDCL[i] = F3Pla->GetMulHitTDCL(i);
    }
    for (Int_t i=0; i<fF3NHitR; ++i) {
      fF3MulHitTDCR[i] = F3Pla->GetMulHitTDCR(i);
    }
  }
  if (F5Pla !=0) {
    fF5TLRaw = F5Pla->GetTLRaw()>0 ? F5Pla->GetTLRaw() : kNaN;
    fF5TRRaw = F5Pla->GetTRRaw()>0 ? F5Pla->GetTRRaw() : kNaN;
    fF5QLRaw = F5Pla->GetQLRaw();
    fF5QRRaw = F5Pla->GetQRRaw();
    fF5QTCLRawStart = F5Pla->GetQTCLRawStart()>0 ? F5Pla->GetQTCLRawStart() : kNaN;
    fF5QTCRRawStart = F5Pla->GetQTCRRawStart()>0 ? F5Pla->GetQTCRRawStart() : kNaN;
    fF5QTCLRawWidth = F5Pla->GetQTCLRawWidth()>0 ? F5Pla->GetQTCLRawWidth() : kNaN;
    fF5QTCRRawWidth = F5Pla->GetQTCRRawWidth()>0 ? F5Pla->GetQTCRRawWidth() : kNaN;
    fF5NHitL = F5Pla->GetNHitL();
    fF5NHitR = F5Pla->GetNHitR();
    for (Int_t i=0; i<fF5NHitL; ++i) {
      fF5MulHitTDCL[i] = F5Pla->GetMulHitTDCL(i);
    }
    for (Int_t i=0; i<fF5NHitR; ++i) {
      fF5MulHitTDCR[i] = F5Pla->GetMulHitTDCR(i);
    }
  }
  if (F7Pla !=0) {
    fF7TLRaw = F7Pla->GetTLRaw()>0 ? F7Pla->GetTLRaw() : kNaN;
    fF7TRRaw = F7Pla->GetTRRaw()>0 ? F7Pla->GetTRRaw() : kNaN;
    fF7QLRaw = F7Pla->GetQLRaw();
    fF7QRRaw = F7Pla->GetQRRaw();
    fF7QTCLRawStart = F7Pla->GetQTCLRawStart()>0 ? F7Pla->GetQTCLRawStart() : kNaN;
    fF7QTCRRawStart = F7Pla->GetQTCRRawStart()>0 ? F7Pla->GetQTCRRawStart() : kNaN;
    fF7QTCLRawWidth = F7Pla->GetQTCLRawWidth()>0 ? F7Pla->GetQTCLRawWidth() : kNaN;
    fF7QTCRRawWidth = F7Pla->GetQTCRRawWidth()>0 ? F7Pla->GetQTCRRawWidth() : kNaN;
    fF7NHitL = F7Pla->GetNHitL();
    fF7NHitR = F7Pla->GetNHitR();
    for (Int_t i=0; i<fF7NHitL; ++i) {
      fF7MulHitTDCL[i] = F7Pla->GetMulHitTDCL(i);
    }
    for (Int_t i=0; i<fF7NHitR; ++i) {
      fF7MulHitTDCR[i] = F7Pla->GetMulHitTDCR(i);
    }
    fF7Q = sqrt(fF7QTCLRawWidth*fF7QTCRRawWidth);
  }

  if (fF3NHitL>0 && fF3NHitR>0) {
    fF3T_BR = ((fF3MulHitTDCL[0]+fF3MulHitTDCR[0])*0.5 - fTRef)*kch2ns;
  }
  if (fF3TLRaw>51591.150 && fF3TRRaw>51591.150+81.2) {
    fF3T_SM = F3Pla->GetTime()>0 ? F3Pla->GetTime() : 0;
  }

  if (fF5NHitL>0 && fF5NHitR>0) {
    fF5DT = fF5MulHitTDCL[0]-fF5MulHitTDCR[0];
    if (fF5DT<-350.)
      fF5DT = kNaN;
    fF5Xpla = f5x(fF5DT);
  }

  if (fF7NHitL>0 && fF7NHitR>0) {
    fF7T_BR = ((fF7MulHitTDCL[0]+fF7MulHitTDCR[0])*0.5 - fTRef)*kch2ns;
  }
  if (fF7TLRaw>48700 && fF7TRRaw>48500) {
    fF7T_SM = F7Pla->GetTime()>0 ? F7Pla->GetTime() : 0;
  }


  if (F13APla!=0 && F13BPla!=0) {
    fF13AQLRaw = F13APla->GetQLRaw()>0 ? F13APla->GetQLRaw() : kNaN;
    fF13AQRRaw = F13APla->GetQRRaw()>0 ? F13APla->GetQRRaw() : kNaN;
    fF13BQLRaw = F13BPla->GetQLRaw()>0 ? F13BPla->GetQLRaw() : kNaN;
    fF13BQRRaw = F13BPla->GetQRRaw()>0 ? F13BPla->GetQRRaw() : kNaN;
  }
  
  fToF37_BR = fF7T_BR-fF3T_BR+kToF37offset_BR;
  fToF37_SM = fF7T_SM-fF3T_SM+kToF37offset_SM;

  fbeta37 = kfpl37/(fToF37_SM*kc);
  fgamma37 = 1/sqrt(1-fbeta37*fbeta37);
  fBetheF = BetheF(fbeta37);
  fZ_tmp = sqrt(fF7Q/(fBetheF-1));
  fZ = fZ_tmp*1.5-3.65;
  fdelta = fF5Xpla/(kxd*100);
  fBrhoF5 = kBrho0*(1+fdelta);
  fAoQ = fBrhoF5/kBrhoop/(kmamu*fbeta37*fgamma37);

  /*
  if (F7Pla !=0 && F13APla !=0){
    // kore deha PID dekinai
    // Nakada method needs to be implemented
    // F7Q ... QDC -> QTC
    // TOF is not sufficient TOF -> F5x correction
    double F7T = 0.5*(F7Pla->GetTLRaw()+F7Pla->GetTRRaw());
    double F13T1 = 0.5*(F13APla->GetTLRaw()+F13APla->GetTRRaw());
    double F7Q = sqrt(F7Pla->GetQLRaw()*F7Pla->GetQRRaw());
    double F7Q_QTC = sqrt(F7Pla->GetQTCLRawWidth()*F7Pla->GetQTCRRawWidth());
    double F13Q1 = sqrt(F13APla->GetQLRaw()*F13APla->GetQRRaw());
    fhpla_pid->Fill(F13T1-F7T,F7Q);
    //fhpla_pid2->Fill(F13T1-F7T,F7Q_QTC);

    if (F5Pla !=0 ){
      double F5dT = F5Pla->GetTLRaw() - F5Pla->GetTRRaw();
      fhpla_tof713dt5->Fill(F13T1-F7T,F5dT);
      
      if (F3Pla !=0 ){
        double F3T = 0.5*(F3Pla->GetTLRaw()+F3Pla->GetTRRaw());
        double F3Q = sqrt(F3Pla->GetQLRaw()*F3Pla->GetQRRaw());
        fhpla_tof313dt5->Fill(F13T1-F3T,F5dT);
        fhpla_tof313dt5_cal->Fill(F13T1-F3T - F5dT / 0.586576,F5dT);
        fhpla_pid2->Fill(F13T1-F3T - F5dT / 0.586576,F7Q_QTC);
        fhpla_pid3->Fill(F13T1-F3T - F5dT / 0.586576,F7Q_QTC);
        //hzvsaoq->Fill(F13T1-F3T - F5dT / 0.586576, F7Q_QTC*0.00230245+9.36899); // Z:1280
	//hzvsaoq->Fill(F13T1-F3T - F5dT / 0.586576, F7Q_QTC*0.00230245+9.36899-2); // Z:1032
      }

    }
  }
  if (F3Pla!=0 && F7Pla!=0) {
    Double_t ff3t_2 = F3Pla->GetTime();
    Double_t ff7t_2 = F7Pla->GetTime();

    Double_t ff3t_1 = kNaN;
    Double_t ff7t_1 = kNaN;
    if (F3Pla->GetNHitL()>0 && F3Pla->GetNHitR()>0) {
      ff3t_1 = (F3Pla->GetMulHitTDCL(0) + F3Pla->GetMulHitTDCR(0))/2 * 0.0244140625;
    }
    if (F7Pla->GetNHitL()>0 && F7Pla->GetNHitR()>0) {
      ff7t_1 = (F7Pla->GetMulHitTDCL(0) + F7Pla->GetMulHitTDCR(0))/2 * 0.0244140625;
    }

    hf3t_1->Fill(ff3t_1);
    hf7t_1->Fill(ff7t_1);
    hf3t_2->Fill(ff3t_2);
    hf7t_2->Fill(ff7t_2);

    htof37_1->Fill(ff7t_1-ff3t_1);
    htof37_2->Fill(ff7t_1-ff3t_2);
    htof37_3->Fill(ff7t_2-ff3t_1);
    htof37_4->Fill(ff7t_2-ff3t_2);
    htof37br_tof37sm -> Fill(ff7t_2-ff3t_2, ff7t_1-ff3t_1);
    htof37diff_tof37sm -> Fill(ff7t_2-ff3t_2, (ff7t_1-ff3t_1) - (ff7t_2-ff3t_2));
  }

  if (F3Pla !=0) {
    for (Int_t n=0; n<F3Pla->GetNHitL(); ++n) {
      hf3lr_2->Fill(F3Pla->GetMulHitTDCL(n));
    }
    for (Int_t n=0; n<F3Pla->GetNHitR(); ++n) {
      hf3rr_2->Fill(F3Pla->GetMulHitTDCR(n));
    }
  }

  if (F5Pla !=0) {
    for (Int_t n=0; n<F5Pla->GetNHitL(); ++n) {
      hf5lr_2->Fill(F5Pla->GetMulHitTDCL(n));
    }
    for (Int_t n=0; n<F5Pla->GetNHitR(); ++n) {
      hf5rr_2->Fill(F5Pla->GetMulHitTDCR(n));
    }
  }

  if (F7Pla !=0) {
    Double_t tl0 = kNaN;
    Double_t tr0 = kNaN;
    for (Int_t n=0; n<F7Pla->GetNHitL(); ++n) {
      hf7lr_2->Fill(F7Pla->GetMulHitTDCL(n));
      tl0 = F7Pla->GetMulHitTDCL(0);
    }
    for (Int_t n=0; n<F7Pla->GetNHitR(); ++n) {
      hf7rr_2->Fill(F7Pla->GetMulHitTDCR(n));
      tr0 = F7Pla->GetMulHitTDCR(0);
    }
    Double_t ql = F7Pla->GetQTCLRawWidth();
    Double_t qr = F7Pla->GetQTCRRawWidth();
    //hf7qrl->Fill(F7Pla->GetQTCLRawWidth(), F7Pla->GetQTCRRawWidth());
    hf7qrl->Fill(ql, qr);
    hf7qtd->Fill(tr0-tl0, sqrt(ql*qr));
    hf7qrtd->Fill(tr0-tl0, log(qr/ql));
  }
  */

  // PPAC
  TClonesArray *ppac_array = (TClonesArray*)sman->FindDataContainer("BigRIPSPPAC");

  TArtPPAC *F5PPAC1A = 0;
  TArtPPAC *F5PPAC1B = 0;
  TArtPPAC *F5PPAC2A = 0;
  TArtPPAC *F5PPAC2B = 0;
  n=ppac_array->GetEntries();
  for (Int_t i=0;i<n;++i){
    TArtPPAC* ppac = (TArtPPAC*)ppac_array->At(i);
    Int_t ID= ppac->GetID();
    if (ID==10){
      F5PPAC1A = ppac;
    } else if (ID==11){
      F5PPAC1B = ppac;
    } else if (ID==12){
      F5PPAC2A = ppac;
    } else if (ID==13){
      F5PPAC2B = ppac;
    }
  }
  // if (F5PPAC1A!=0 && F5PPAC1B!=0 && F5PPAC2A!=0 && F5PPAC2B!=0) {
    
  // }
 
  fF3_X = kNaN;
  fF3_Y = kNaN;
  fF3_A = kNaN;
  fF3_B = kNaN;
  fF5_X = kNaN;
  fF5_Y = kNaN;
  fF5_A = kNaN;
  fF5_B = kNaN;
  fF7_X = kNaN;
  fF7_Y = kNaN;
  fF7_A = kNaN;
  fF7_B = kNaN;

  //TClonesArray *fp_array = fCalibFocalPlane->GetFocalPlaneArray();
  TClonesArray *fp_array = (TClonesArray*)sman->FindDataContainer("BigRIPSFocalPlane");
  n = fp_array->GetEntries();
  for (int i=0;i<n;++i){
    TVectorD *vec;
    TArtFocalPlane *focalplane = (TArtFocalPlane*)fp_array->At(i);
    Int_t ID = focalplane->GetID();
    vec=focalplane->GetOptVector();
    // //F7X = (*vec)(0); F7A = (*vec)(1); F7Y = (*vec)(2); F7B = (*vec)(3);
    // hidx->Fill(ID, (*vec)(0));
    // hida->Fill(ID, (*vec)(1));
    // hidy->Fill(ID, (*vec)(2));
    // hidb->Fill(ID, (*vec)(3));

    if ((*vec)(0)>-1000 && (*vec)(1)>-1000 && (*vec)(2)>-1000 && (*vec)(3)>-1000){
      if (ID==4) {
	fF3_X = (*vec)(0);
	fF3_A = (*vec)(1);
	fF3_Y = (*vec)(2);
	fF3_B = (*vec)(3);
      } else if (ID==6) {
	fF5_X = (*vec)(0);
	fF5_A = (*vec)(1);
	fF5_Y = (*vec)(2);
	fF5_B = (*vec)(3);
      } else if (ID==8) {
	fF7_X = (*vec)(0);
	fF7_A = (*vec)(1);
	fF7_Y = (*vec)(2);
	fF7_B = (*vec)(3);
      }
    }
    /*
    if (F5Pla!=0 && F5PPAC1A!=0 && F5PPAC1B!=0 && F5PPAC2A!=0 && F5PPAC2B!=0) {
      //Double_t f5dt = F5Pla->GetTLRaw() - F5Pla->GetTRRaw();
      //Double_t f5dt = F5Pla->GetMulHitTDCL(0) - F5Pla->GetMulHitTDCR(0);
      Double_t f5dt = kNaN;
      if (F5Pla->GetNHitL()>0 && F5Pla->GetNHitR()>0) {
	f5dt = F5Pla->GetMulHitTDCL(0) - F5Pla->GetMulHitTDCR(0);
      }
