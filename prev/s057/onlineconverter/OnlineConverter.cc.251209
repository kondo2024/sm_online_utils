const Double_t kfpl37 = 46566+205*2; // mm; flight path length from F3Pla to F7Pla
const Double_t kc = 299.792458; // mm/ns; light velocity
const Double_t kme = 511e3; // eV/c2; electron mass
const Double_t kI = 64.7; // eV; mean excitation energy of plastic scintillator
const Double_t kmamu = 0.93149410372; // GeV; atomic mass unit
const Double_t kBrho0 = 6.6096; // Tm; rigidity at F5
const Double_t kxd = 33.; // mm/%; (x|delta)
const Double_t kBrhoop = 3.3356; // Tm/(GeV/c)

const Double_t kch2ns = 0.0244140625; // ns; V1290

//const Double_t kToF37offset_BR = 309; // ns; rough evaluation w/ LISE++ estimation
const Double_t kToF37offset_BR = 309+1.4; // ns; phenomenological correction
const Double_t kToF37offset_SM = kToF37offset_BR-1.54;

const Double_t kBDC1_Z = -(4312.30+2293.19+34); // 2025.06.27 23:50
const Double_t kBDC2_Z = -(4312.30+1293.49+34);
const Double_t kTarget_Z = -(4312.30-57-25); // center of the target

//_________________________________________________________________________________
// function to exit loop at keyboard interrupt.
bool stoploop = false;
void stop_interrupt(int) {
  printf("keyboard interrupt\n");
  stoploop = true;
}
//_________________________________________________________________________________
void dump_pla(TArtPlastic* pla)
{
  Int_t fTLRaw = pla->GetTLRaw();
  Int_t fTRRaw = pla->GetTRRaw();
  Int_t fQLRaw = pla->GetQLRaw();
  Int_t fQRRaw = pla->GetQRRaw();
  Int_t fQTCLRawStart = pla->GetQTCLRawStart();
  Int_t fQTCRRawStart = pla->GetQTCRRawStart();
  Int_t fQTCLRawWidth = pla->GetQTCLRawWidth();
  Int_t fQTCRRawWidth = pla->GetQTCRRawWidth();
  Int_t fNHitL = pla->GetNHitL();
  Int_t fNHitR = pla->GetNHitR();
  Int_t fMulHitTDCL0 = (fNHitL>0) ? pla->GetMulHitTDCL(0) : -9999;
  Int_t fMulHitTDCR0 = (fNHitR>0) ? pla->GetMulHitTDCR(0) : -9999;
  //printf("%10d %10d %10d %10d ", fTLRaw, fTRRaw, fQLRaw, fQRRaw);
  //printf("%10d %10d %10d %10d ", fQTCLRawStart, fQTCRRawStart, fQTCLRawWidth, fQTCRRawWidth);
  //printf("%10d %10d %10d %10d\n", fNHitL, fNHitR, fMulHitTDCL0, fMulHitTDCR0);
}
double f5x(double f5dt)
{
  return
    -122.589
    -1.15179 *pow(f5dt,1.)
    -0.0331848 *pow(f5dt,2.)
    -0.000661241 *pow(f5dt,3.)
    -7.61878e-06 *pow(f5dt,4.)
    -5.2709e-08 *pow(f5dt,5.)
    -2.17764e-10 *pow(f5dt,6.)
    -5.20103e-13 *pow(f5dt,7.)
    -6.55889e-16 *pow(f5dt,8.)
    -3.33996e-19 *pow(f5dt,9.);
}
double BetheF(double beta)
{
  return log(2*kme*beta*beta/((1-beta*beta)*kI)-beta*beta)/(beta*beta);
}
//_________________________________________________________________________________
void OnlineConverter::Run(ULong64_t nmax)// main 
{
  if(nmax>0) fNeveMax = nmax ;
  if (!fInitialize) {
    Init();
  }

  if (!fIsHistBooked) {
    BookHist();
    BookUserHist();
  }

  EventLoop();
  fRootFile->Write();
}
//_________________________________________________________________________________
void OnlineConverter::Init()
{
  // Path for Input files
  //const char *TDCdist = "db/dc/tdcdists_run1198.root";// 20250629, Ca beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1173.root";// 20250628, Ca beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1171.root";// 20250628, Ca beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1172.root";// 20250628, Ca beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1145.root";// 20250628, Ca beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1143.root";// 20250628, Ca beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1134.root";// 20250627, p beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1130.root";// 20250627, 3He beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1129.root";// 20250627, 3He beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1122.root";// 20250627, 3He beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1121.root";// 20250627, 3He beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1108.root";// 20250627, t beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1088.root";// 20250627, alpha beam, multihit, BDC2=900V
  //const char *TDCdist = "db/dc/tdcdists_run1086.root";// 20250627, alpha beam, multihit, BDC2=900V
  //const char *TDCdist = "db/dc/tdcdists_run1082.root";// 20250627, alpha beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1070.root";// 20250625, d beam, multihit
  //const char *TDCdist = "db/dc/tdcdists_run1061.root";// 20250625, d beam
  //const char *TDCdist = "db/dc/tdcdists_run1052.root";// 20250625, alpha beam
  //const char *TDCdist = "db/dc/tdcdists_run1046.root";// 20250625, d beam
  //const char *TDCdist = "db/dc/tdcdists_run1007.root";// 20250625, Ca beam
  //const char *TDCdist = "db/dc/tdcdists_run0096.root";
  //const char *TDCdist = "db/dc/tdcdists_run0043.root";
  //const char *TDCdist = "db/dc/tdcdists_run0033.root";//

  char *TDCdist;
  if (1071<=fRunNumber && fRunNumber<1082) {
    // d beam
    std::cout << "STC for deuteron beam" << std::endl;
    TDCdist = "db/dc/tdcdists_run1070.root";// 20250625, d beam, multihit
  } else if (1082<=fRunNumber && fRunNumber<1108) {
    // a beam
    std::cout << "STC for alpha beam" << std::endl;
    TDCdist = "db/dc/tdcdists_run1088.root";// 20250627, alpha beam, multihit, BDC2=900V
  } else if (1108<=fRunNumber && fRunNumber<1121) {
    // t beam
    std::cout << "STC for triton beam" << std::endl;
    TDCdist = "db/dc/tdcdists_run1108.root";// 20250627, t beam, multihit
  } else if (1121<=fRunNumber && fRunNumber<1134) {
    // 3He beam
    std::cout << "STC for 3He beam" << std::endl;
    TDCdist = "db/dc/tdcdists_run1130.root";// 20250627, 3He beam, multihit
  } else if (1134<=fRunNumber && fRunNumber<1140) {
    // p beam
    std::cout << "STC for proton beam" << std::endl;
    TDCdist = "db/dc/tdcdists_run1134.root";// 20250627, p beam, multihit
  } else {
    // Ca beam
    std::cout << "STC for Ca beam" << std::endl;
    TDCdist = "db/dc/tdcdists_run1198.root";// 20250629, Ca beam, multihit
  }

  // change for your experiment
  fProcessorArray.push_back(new CoinDataProcessor);

  //fProcessorArray.push_back(new PlasticDataProcessor);
  //PlasticDataProcessor *platic_processor = new PlasticDataProcessor("db/SAMURAIPlastic_20250529_v2.xml");
  //PlasticDataProcessor *platic_processor = new PlasticDataProcessor("db/SAMURAIPlastic_20251003_kubota.xml");
  PlasticDataProcessor *platic_processor = new PlasticDataProcessor("db/SAMURAIPlastic_20251009_kubota.xml"); // Multihit TDC/QTC gate for multihit rejection
  //PlasticDataProcessor *platic_processor = new PlasticDataProcessor("db/SAMURAIPlastic_20251110_lightion_kubota.xml"); // disable qtc_underflow for light ion analysis
  fProcessorArray.push_back(platic_processor);

  fProcessorArray.push_back(new PPACDataProcessor);
  fProcessorArray.push_back(new FocalPlaneDataProcessor);

  BDCDataProcessor *bdc_processor = new BDCDataProcessor(TDCdist);
//  bdc_processor->SetTDCWindow(1,4000,4700);// writtein BDCDataProcessor
//  bdc_processor->SetTDCWindow(2,4000,4700);

//  bdc_processor->SetBDC1Z(4170.0-6667.3555);// from gameplan 2025.05.29
//  bdc_processor->SetBDC2Z(4170.0-5667.7865);
//  bdc_processor->SetBDC1Z(2293.19+57.);// from measure values 2025.06.25
//  bdc_processor->SetBDC2Z(1293.49+57.);// tgt pos is upstream face
//  bdc_processor->SetTargetZ(0.0);

  // bdc_processor->SetBDC1Z(-(4312.30+2293.19+34)); // 2025.06.27 23:50
  // bdc_processor->SetBDC2Z(-(4312.30+1293.49+34));
  // bdc_processor->SetTargetZ(-(4312.30-57-25)); // center of the target
  bdc_processor->SetBDC1Z(kBDC1_Z);
  bdc_processor->SetBDC2Z(kBDC2_Z);
  bdc_processor->SetTargetZ(kTarget_Z);
  fProcessorArray.push_back(bdc_processor);

//  fProcessorArray.push_back(new FDC1DataProcessor(TDCdist));
//  fProcessorArray.push_back(new FDC2DataProcessor(TDCdist));
//
//  fProcessorArray.push_back(new HODPlaDataProcessor);
//  fProcessorArray.push_back(new NEBULADataProcessor);
//
//  PDCDataProcessor *pdc_processor = new PDCDataProcessor;
//  pdc_processor->DoTracking(false);
//  fProcessorArray.push_back(pdc_processor);
  

  fnx=4;
  fny=4;
  fResetCount=20000;
  fDrawTimeInterval=10;// sec

  festore = new TArtEventStore();
  fNeve = 0;
  fNeve_monitor = 0;

  fInitialize = true;

}
